# =========================================================================
# Aegis Bank Ecosystem Configuration Variables Template
# =========================================================================
# Copy this file to '.env' in the same folder and customize values.
# Do NOT commit the '.env' file with real secrets to version control.

# --- COMMON SETTINGS ---
DEPLOY_HOST=localhost

# --- DATABASE (POSTGRESQL) ---
POSTGRES_DB=aegis
POSTGRES_USER=postgres
POSTGRES_PASSWORD=          # REQUIRED: Set a strong password (min 20 chars, mixed case + digits)
POSTGRES_PORT=5432

# --- KAFKA HA CLUSTER (3-Node KRaft) ---
KAFKA_PORT_1=9094
KAFKA_PORT_2=9095
KAFKA_PORT_3=9096
KAFKA_CLUSTER_ID=AegisKafkaCluster001xyzw

# --- SPRING BOOT JAVA BACKEND (BE) ---
BE_PORT=8080
JWT_SECRET=                 # REQUIRED: Generate with `openssl rand -hex 32`
JWT_EXPIRATION=86400000
AEGIS_SECURITY_SYNC_TOKEN=  # REQUIRED: Generate with `openssl rand -hex 32`

# --- GO SOC BACKEND & REACT SOC DASHBOARD ---
DASHBOARD_API_PORT=8082
DASHBOARD_FE_PORT=3001

# --- NEXT.JS FRONTEND ---
FE_PORT=3000

# --- NGINX API GATEWAY / REVERSE PROXY ---
NGINX_PORT=80

# --- HASHICORP VAULT ---
VAULT_ROOT_TOKEN=           # REQUIRED: HashiCorp Vault root token ID

# --- INTEGRATIONS & THIRD-PARTY SECRETS ---
FORTINET_API_TOKEN=         # REQUIRED: Fortinet API firewall token
CROWDSTRIKE_CLIENT_SECRET=  # REQUIRED: Crowdstrike OAuth client secret
ENTRA_CLIENT_SECRET=        # REQUIRED: Microsoft Entra OAuth client secret
AD_LDAP_PASSWORD=           # REQUIRED: Active Directory LDAP password
AWS_SECRET_ACCESS_KEY=      # REQUIRED: AWS S3 log archiver secret key

