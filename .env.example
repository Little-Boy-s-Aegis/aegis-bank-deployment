# =========================================================================
# Aegis Bank Ecosystem Configuration Variables Template
# =========================================================================
# Copy this file to '.env' in the same folder and customize values.
# Do NOT commit the '.env' file with real secrets to version control.

# --- COMMON SETTINGS ---
DEPLOY_HOST=localhost

# --- DATABASE (POSTGRESQL) ---
POSTGRES_DB=aegis
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1
POSTGRES_PORT=5432

# --- KAFKA HA CLUSTER (3-Node KRaft) ---
KAFKA_PORT_1=9094
KAFKA_PORT_2=9095
KAFKA_PORT_3=9096
KAFKA_CLUSTER_ID=AegisKafkaCluster001xyzw

# --- SPRING BOOT JAVA BACKEND (BE) ---
BE_PORT=8080
JWT_SECRET=9a65a3d7ebe40f1a9aefefefae2a11b98a3e7456d98124ef1240e94abef87ea9
JWT_EXPIRATION=86400000
AEGIS_SECURITY_SYNC_TOKEN=aegis-secret-security-sync-token-2026

# --- GO SOC BACKEND & REACT SOC DASHBOARD ---
DASHBOARD_API_PORT=8082
DASHBOARD_FE_PORT=3001

# --- NEXT.JS FRONTEND ---
FE_PORT=3000

# --- NGINX API GATEWAY / REVERSE PROXY ---
